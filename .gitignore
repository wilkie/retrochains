# Rust
target/
**/*.rs.bk

# Node / pnpm
node_modules/
.pnpm-store/
*.log
npm-debug.log*
pnpm-debug.log*

# Build artifacts
dist/
build/
pkg/

# Oracle distributions. The binaries aren't ours to redistribute, so for each
# toolchain we ship a SHA-256 manifest (`BC2.sha256`, `MSC500.sha256`,
# `LATTICE*.sha256`) and a how-to-acquire doc (`BC2.md`, `MSC500.md`,
# `LATTICE*.md`) instead of the zip itself. The oracle crate lazily unpacks
# each zip into its own gitignored dir on first use. See
# specs/plans/SECOND_COMPILER.md.
/BC2.zip
/MSC*.zip
/LATTICE*.zip
.bc2/
.msc500/
.lattice2/
.lattice3/

# Stray Borland-built artifacts at the repo root (fixture outputs belong under
# fixtures/ and ARE tracked, so we don't blanket-ignore these extensions).
/*.OBJ
/*.obj
/*.EXE
/*.exe
/*.MAP
/*.map
/*.ASM
/*.asm

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*~

# Env
.env
.env.local

# Agents
.claude
scripts/bulk_msc_capture.log
scripts/bulk_msc_capture.out
