# Rust
target/
**/*.rs.bk

# Node / pnpm
node_modules/
.pnpm-store/
*.log
npm-debug.log*
pnpm-debug.log*

# Build artifacts
dist/
build/
pkg/

# Extracted Borland C++ 2.0 install tree (extracted lazily from BC2.zip by the
# oracle crate; BC2.zip itself is tracked, the unpacked contents are not).
.bc2/

# Oracle distributions for the second/third compiler targets. The binaries
# aren't ours to redistribute, so we ship a SHA-256 manifest (`MSC500.sha256`,
# `LATTICE*.sha256`) and a how-to-acquire doc (`MSC500.md`, `LATTICE*.md`)
# instead of the zip itself. See specs/plans/SECOND_COMPILER.md.
/MSC*.zip
/LATTICE*.zip
.msc500/
.lattice2/
.lattice3/

# Stray Borland-built artifacts at the repo root (fixture outputs belong under
# fixtures/ and ARE tracked, so we don't blanket-ignore these extensions).
/*.OBJ
/*.obj
/*.EXE
/*.exe
/*.MAP
/*.map
/*.ASM
/*.asm

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*~

# Env
.env
.env.local

# Agents
.claude
scripts/bulk_msc_capture.log
scripts/bulk_msc_capture.out
