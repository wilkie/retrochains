{
  "name": "@retrochains/explorer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Web corpus explorer: browse fixtures, compile in-browser with the WASM toolchain, verify byte-exactly against the goldens, and decompile in reverse",
  "scripts": {
    "gen:manifest": "node ../../scripts/gen-fixture-manifest.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:integration": "node --test test/*.test.mjs",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^6.1.0",
    "@retrochains/bcc": "workspace:*",
    "@retrochains/decompile": "workspace:*",
    "@retrochains/msc": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  }
}
